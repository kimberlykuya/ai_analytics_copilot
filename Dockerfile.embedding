FROM python:3.14-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    sentence-transformers \
    fastapi \
    "uvicorn[standard]"

# Pre-download all-MiniLM-L6-v2 at build time so startup is instant
# and the image is self-contained (no HuggingFace network calls at runtime)
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"

COPY scripts/embedding_service.py .

EXPOSE 8001

CMD ["uvicorn", "embedding_service:app", "--host", "0.0.0.0", "--port", "8001"]
